# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
test-execution-report.md
test-report*.md

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# docs (plans, generated documentation)
/docs

# images (screenshots, temporary visuals)
*.png
# …but PWA/app icons in public/ MUST ship — Next serves them as static assets.
!public/**/*.png

# playwright-mcp (logs, snapshots)
.playwright-mcp/
*.log

# --- repo cleanup: keep scratch & one-off artifacts out of the repo ---

# scratch / working dir (categorization slices, ideation, db dumps)
/.md-work/

# one-off shell scripts (AWS teardown/discovery, cleanup helpers)
*.sh

# playwright test suite (removed; MCP browser snapshots ignored above)
/e2e/
/playwright.config.ts

# database dumps — migrations in supabase/migrations/ are intentionally NOT ignored
*-backup.sql
db-backup.sql
